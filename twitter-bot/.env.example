# Twitter API v2 (https://developer.twitter.com)
# Necesitas al menos el plan Basic ($100/mes) para leer menciones y DMs
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Twitter account usernames (sin @)
TWITTER_BOT_USERNAME=nadiedebesmaya
TWITTER_BAND_USERNAME=somosbesmaya

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Configuracion del bot
POLLING_INTERVAL_MS=1800000
MAX_DAILY_REPLIES=100
DRY_RUN=false
